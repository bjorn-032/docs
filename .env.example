# OIDC (PocketID)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://your-domain/auth/callback.php
OIDC_ISSUER=https://your-accounts-domain
OIDC_AUTH_ENDPOINT=https://your-accounts-domain/authorize
OIDC_TOKEN_ENDPOINT=https://your-accounts-domain/api/oidc/token
OIDC_USERINFO_ENDPOINT=https://your-accounts-domain/api/oidc/userinfo
OIDC_LOGOUT_ENDPOINT=https://your-accounts-domain/api/oidc/end-session
